---
import '../styles/global.css';
import Header from "../components/Header.astro";
import SEOSchema from "../components/SEOSchema.astro";
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- SEO Meta Tags -->
		<title>Santiago Castillo - Instalador de Cubiertas Profesional</title>
		<meta name="description" content="Instalador de cubiertas con más de 3 años de experiencia. Especialista en techos de tejas Standing Seam, Skydeck, Arquitectónicas, Termoacústicas y Policarbonato." />
		<meta name="keywords" content="instalador de cubiertas, tejas, techos, cubierta termoacústica, Standing Seam, Skydeck, constructor, bogotá, colombia" />
		<meta name="author" content="Santiago Castillo" />
		
		<!-- Open Graph Tags -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content="Santiago Castillo - Instalador de Cubiertas Profesional" />
		<meta property="og:description" content="Especialista en instalación de cubiertas de alta calidad con experiencia en proyectos residenciales y comerciales." />
		<meta property="og:image" content="https://res.cloudinary.com/dme4ett0o/image/upload/v1753754471/foto-perfil-og_iwwjed.jpg" />
		<meta property="og:url" content="https://santiago-castillo-23.github.io/portafolio" />
		
		<!-- Twitter Card Tags -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content="Santiago Castillo - Instalador de Cubiertas" />
		<meta name="twitter:description" content="Especialista en instalación de cubiertas profesionales" />
		
		<!-- Canonical URL -->
		<link rel="canonical" href="https://santiago-castillo-23.github.io/portafolio" />
		
		<!-- Sitemap y Robots -->
		<link rel="sitemap" href="/portafolio/sitemap.xml" />
		
		<SEOSchema />
	</head>
	<body>
		<Header/>
		<slot />
	</body>
</html>

<style is:global>
	html {
		font-family: 'Onest Variable', sans-serif;
	},
	body {
		margin: 0;
		width: 100%;
		height: 100%;
		background-color: white;
	}
</style>
